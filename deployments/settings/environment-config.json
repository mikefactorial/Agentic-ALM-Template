{
  "$comment": "Central platform configuration — the only file a new client must edit. Defines solution areas, all environments (with URLs), and deployment packages. Scripts and workflows read from here instead of having hardcoded values.",
  "clientName": "{{CLIENT_NAME}}",
  "productDescription": "{{PRODUCT_DESCRIPTION}}",
  "githubOrg": "{{GITHUB_ORG}}",
  "repoName": "{{REPO_NAME}}",
  "publisher": "{{PUBLISHER}}",
  "packageTag": "{{PACKAGE_TAG}}",
  "packageProjectPath": "deployments/package/Deployer/PlatformPackage.csproj",
  "solutionAreas": [
    {
      "name": "{{SOLUTION_NAME}}",
      "prefix": "{{SOLUTION_PREFIX}}",
      "role": "{{SOLUTION_ROLE}}",
      "mainSolution": "{{SOLUTION_PREFIX}}_{{SOLUTION_NAME}}",
      "cdsproj": "src/solutions/{{SOLUTION_PREFIX}}_{{SOLUTION_NAME}}/{{SOLUTION_PREFIX}}_{{SOLUTION_NAME}}.cdsproj",
      "pluginsPath": "src/plugins/{{SOLUTION_PREFIX}}_{{SOLUTION_NAME}}",
      "pluginsSln": "src/plugins/{{SOLUTION_PREFIX}}_{{SOLUTION_NAME}}/{{PUBLISHER}}.{{SOLUTION_NAME}}.Plugins.sln",
      "corePluginRef": null,
      "controlPreBuildPaths": [],
      "devEnv": "{{ENV_PREFIX}}-dev",
      "integrationEnv": "{{ENV_PREFIX}}-integration"
    }
  ],
  "innerLoopEnvironments": [
    { "slug": "{{ENV_PREFIX}}-dev",         "url": "https://{{ENV_PREFIX}}-dev-{{TENANT_SLUG}}.crm.dynamics.com/" },
    { "slug": "{{ENV_PREFIX}}-integration", "url": "https://{{ENV_PREFIX}}-int-{{TENANT_SLUG}}.crm.dynamics.com/" }
  ],
  "environments": [
    { "slug": "{{ENV_PREFIX}}-dev-test", "url": "https://{{ENV_PREFIX}}-dvt-{{TENANT_SLUG}}.crm.dynamics.com/" },
    { "slug": "{{ENV_PREFIX}}-test",     "url": "https://{{ENV_PREFIX}}-tst-{{TENANT_SLUG}}.crm.dynamics.com/" },
    { "slug": "{{ENV_PREFIX}}-prod",     "url": "https://{{ENV_PREFIX}}-prd-{{TENANT_SLUG}}.crm.dynamics.com/" }
  ],
  "packageGroups": [
    {
      "name": "{{SOLUTION_NAME}}",
      "solutions": ["{{SOLUTION_PREFIX}}_{{SOLUTION_NAME}}"],
      "dataSolution": "{{SOLUTION_PREFIX}}_{{SOLUTION_NAME}}",
      "environments": ["{{ENV_PREFIX}}-dev-test", "{{ENV_PREFIX}}-test", "{{ENV_PREFIX}}-prod"]
    }
  ]
}
